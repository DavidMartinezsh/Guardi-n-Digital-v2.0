# ==============================================================================
# GUARDIÁN DIGITAL v2.0 - .env.example
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el archivo .env a Git.
# ==============================================================================

# --- Base de Datos MySQL ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=guardian_user
DB_PASSWORD=upyJ2Al62nVs
DB_NAME=guardian_bot

# --- Google Gemini AI ---
GEMINI_API_KEY=AIzaSyAJahsH0rSCw9NyvFkm-VjeB4M_eGy2OmU

# --- Evolution API (WhatsApp) ---
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=TU_EVOLUTION_API_KEY
EVOLUTION_INSTANCE=guardian_instance

# --- Caché de Perfiles ---
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SEGUNDOS=3600      # 1 hora

# --- Protección Anti-Spam ---
SPAM_VENTANA_SEGUNDOS=60     # Ventana de análisis
SPAM_MAX_MENSAJES=30         # Máx. mensajes en la ventana
SPAM_MAX_IDENTICOS=5         # Máx. mensajes iguales seguidos
SPAM_INTERVALO_MIN_MS=300    # Intervalo mínimo entre mensajes (ms)
SPAM_BLOQUEO_TEMPORAL_SEG=300 # 5 minutos de bloqueo temporal

# --- Pesos del Score Central (deben sumar 1.0) ---
SCORE_PESO_BIOMETRIA=0.40
SCORE_PESO_MANIPULACION=0.30
SCORE_PESO_ESTAFA=0.20
SCORE_PESO_IMPROVISACION=0.10

# --- Módulos Opcionales ---
RAG_ENABLED=false
VISION_ENABLED=false
VOICE_ENABLED=false

# --- RAG (si RAG_ENABLED=true) ---
CHROMA_PERSIST_DIR=/var/guardian/chroma_db

# --- Voz (si VOICE_ENABLED=true) ---
WHISPER_MODEL=base   # tiny | base | small | medium | large

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=/var/log/guardian_digital.log
